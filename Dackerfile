FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN dpkg --add-architecture i386 && \
    apt update && \
    apt install -y --no-install-recommends \
    sudo \
    wget \
    curl \
    ca-certificates \
    dbus-x11 \
    x11-xserver-utils \
    xfce4 \
    xfce4-goodies \
    tightvncserver \
    xfonts-base \
    xfonts-75dpi \
    xfonts-100dpi \
    wine64 \
    wine32 \
    winetricks \
    && apt clean && rm -rf /var/lib/apt/lists/*

RUN useradd -ms /bin/bash devuser && \
    echo "devuser:1234" | chpasswd && \
    adduser devuser sudo

USER devuser
WORKDIR /home/devuser

ENV USER=devuser
ENV HOME=/home/devuser

RUN mkdir -p /home/devuser/.vnc && \
    printf '#!/bin/bash\nxrdb $HOME/.Xresources\nstartxfce4 &\n' > /home/devuser/.vnc/xstartup && \
    chmod +x /home/devuser/.vnc/xstartup && \
    echo "123456" | vncpasswd -f > /home/devuser/.vnc/passwd && \
    chmod 600 /home/devuser/.vnc/passwd

EXPOSE 5901

CMD bash -c "vncserver :1 -geometry 1280x800 -depth 24 && tail -f /dev/null"
